    "import numpy as np \n",
    "\n",
    "fun = input(\"Enter a function f(x)=\")\n",
    "a=float(input(\"enter limit a:\"))\n",
    "b=float(input(\"enter limit b:\"))\n",
    "N=1000\n",
    "x_random = np.random.uniform(a, b, N)\n",
    "y= eval(fun)\n",
    "estimate = (b - a) * np.mean(y)\n",
    "print(f\"Monte Carlo Estimate: {estimate:.4f}\")"
   ]
